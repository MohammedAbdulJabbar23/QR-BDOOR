{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=albadour;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "Al-Badour-Hospital-Super-Secret-JWT-Key-2026-Minimum-32-Characters!",
    "Issuer": "AlBadourHospital",
    "Audience": "AlBadourApp"
  },
  "FileStorage": {
    "BasePath": "./storage"
  },
  "BaseUrl": "https://albadour-hospital.com",
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "GET:/api/verify/*",
        "Period": "1m",
        "Limit": 30
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
