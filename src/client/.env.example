# ============================================
# Al-Badour Hospital - Frontend Environment
# ============================================
# Copy this file to .env and adjust for your environment.
# All variables must start with VITE_ to be exposed to the client.

# --- Dev Server Port ---
VITE_PORT=5173

# --- API Proxy Target (dev server only) ---
# The backend URL that Vite proxies /api requests to during development.
VITE_API_URL=http://localhost:5293

# --- API Base URL (runtime) ---
# Used by axios in the browser. Leave as /api when the frontend
# is served from the same origin as the backend (default).
# Set to a full URL (e.g. https://api.albadour-hospital.com/api)
# if the API is on a different origin in production.
# VITE_API_BASE_URL=/api
