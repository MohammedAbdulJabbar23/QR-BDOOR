# ============================================
# Al-Badour Hospital - Environment Variables
# ============================================
# Copy this file to .env and fill in production values.
# These map to appsettings.json keys via the standard
# ASP.NET Core configuration provider (double-underscore = nesting).

# --- Database ---
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=albadour;Username=postgres;Password=postgres

# --- JWT ---
Jwt__Key=CHANGE-ME-TO-A-LONG-RANDOM-SECRET-AT-LEAST-32-CHARS
Jwt__Issuer=AlBadourHospital
Jwt__Audience=AlBadourApp

# --- MinIO / S3 Storage ---
Minio__Endpoint=localhost:9000
Minio__AccessKey=minioadmin
Minio__SecretKey=minioadmin
Minio__BucketName=albadour
Minio__UseSSL=false

# --- Base URL ---
# Public-facing URL of the application (used for QR code verification links).
# In development: http://localhost:5173
# In production: https://your-domain.com
BaseUrl=https://albadour-hospital.com

# --- Serilog ---
Serilog__MinimumLevel__Default=Information
